generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Note {
  id          String    @id @default(cuid())
  title       String
  content     String
  fileType    String    @default("text")
  concepts    String    @default("[]")
  embedding   String    @default("[]")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  recommendations Recommendation[]
}

model Recommendation {
  id          String   @id @default(cuid())
  noteId      String
  note        Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  type        String
  title       String
  description String
  url         String
  thumbnail   String   @default("")
  source      String
  relevance   Float    @default(0)
  concepts    String   @default("[]")
  createdAt   DateTime @default(now())
}

model FeedItem {
  id          String   @id @default(cuid())
  type        String
  title       String
  description String
  url         String
  thumbnail   String   @default("")
  source      String
  concepts    String   @default("[]")
  relevance   Float    @default(0)
  noteId      String?
  createdAt   DateTime @default(now())
}
